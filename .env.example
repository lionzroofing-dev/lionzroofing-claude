# reCAPTCHA v2 — get from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=        # Site key (public — safe to expose)
RECAPTCHA_SECRET_KEY=                  # Secret key (server only — never expose)

# Google Analytics 4 — get from analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=                     # Measurement ID, format: G-XXXXXXXXXX

# Google Search Console — get from search.google.com/search-console → Verify → HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=          # Content value of the verification meta tag

# Meta (Facebook) Pixel — get from business.facebook.com → Events Manager
NEXT_PUBLIC_META_PIXEL_ID=             # Pixel ID (numeric)

# Contact form webhook — create a Zapier/Make/n8n webhook that emails submissions
FORM_WEBHOOK_URL=                      # Full webhook URL

